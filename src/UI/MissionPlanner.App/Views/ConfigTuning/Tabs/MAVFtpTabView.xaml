<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MissionPlanner.App.Views.ConfigTuning.Tabs.MAVFtpTabView" Title="Vehicle Files">
    <Grid Padding="16" RowDefinitions="Auto,*,Auto" RowSpacing="12">
        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="8">
            <Button BackgroundColor="Transparent" Text="↑" Command="{Binding NavigateUpCommand}" IsEnabled="{Binding CanNavigateUp}" />
            <Label Grid.Column="1" Text="{Binding CurrentPath}" FontAttributes="Bold" VerticalTextAlignment="Center" LineBreakMode="MiddleTruncation" />
            <Button BackgroundColor="Transparent" Grid.Column="2" Text="Refresh" Command="{Binding RefreshCommand}" />
            <Button BackgroundColor="Transparent" Grid.Column="3" Text="Open" Command="{Binding OpenSelectedCommand}" />
            <Button BackgroundColor="Transparent" Grid.Column="4" Text="Reset sessions" Command="{Binding ResetSessionsCommand}" />
        </Grid>
        <Grid Grid.Row="1">
            <CollectionView ItemsSource="{Binding Entries}" SelectedItem="{Binding SelectedEntry}" SelectionMode="Single" 
                            EmptyView="{Binding EmptyText}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="8" ColumnDefinitions="36,*,120,140">
                            <Label Text="{Binding Icon}" FontSize="20" />
                            <Label Grid.Column="1" Text="{Binding Name}" VerticalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="{Binding TypeText}" VerticalTextAlignment="Center" />
                            <Label Grid.Column="3" Text="{Binding SizeText}" HorizontalTextAlignment="End" VerticalTextAlignment="Center" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
        <VerticalStackLayout Grid.Row="2" Spacing="6">
            <Label Text="{Binding ErrorText}" TextColor="Red" />
            <ProgressBar Progress="{Binding TransferProgress}" />
            <Label Text="{Binding TransferDetails}" FontSize="12" />
            <Label Text="{Binding StatusText}" />
            <HorizontalStackLayout Spacing="8">
                <Button BackgroundColor="Transparent" Text="Download selected" Command="{Binding DownloadSelectedCommand}" />
                <Button BackgroundColor="Transparent" Text="Cancel" Command="{Binding CancelCommand}" IsEnabled="{Binding IsBusy}" />
                <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </Grid>
</ContentPage>
