                        </material:DataGridColumn>
                        <material:DataGridColumn Title="Value">
                            <material:DataGridColumn.CellItemTemplate>
                                <DataTemplate x:DataType="vm:ParameterItemViewModel">
                                    <Label VerticalOptions="Center" MaximumHeightRequest="40" HorizontalOptions="Start" Text="{Binding Value}" />
                                </DataTemplate>
