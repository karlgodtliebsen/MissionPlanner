<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:sections="clr-namespace:MissionPlanner.App.Views.InitSetup.MandatoryHardware.Sections"
             x:Class="MissionPlanner.App.Views.InitSetup.MandatoryHardware.Sections.FirmwareSetupView"
             x:DataType="sections:FirmwareSetupViewModel">
    <VerticalStackLayout Spacing="10">
        <Label Text="Connected identity" FontSize="18" FontAttributes="Bold" />
        <Grid ColumnDefinitions="180,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="5">
            <Label Text="Vehicle" FontAttributes="Bold" />
            <Label Grid.Column="1" Text="{Binding VehicleLabel}" />
            <Label Grid.Row="1" Text="Firmware" FontAttributes="Bold" />
            <Label Grid.Row="1" Grid.Column="1" Text="{Binding FirmwareVersion}" />
            <Label Grid.Row="2" Text="Release type / Git" FontAttributes="Bold" />
            <Label Grid.Row="2" Grid.Column="1" Text="{Binding ReleaseType, StringFormat='{0}'}" />
            <Label Grid.Row="3" Text="Git hash" FontAttributes="Bold" />
            <Label Grid.Row="3" Grid.Column="1" Text="{Binding GitHash}" />
            <Label Grid.Row="4" Text="Board version" FontAttributes="Bold" />
            <Label Grid.Row="4" Grid.Column="1" Text="{Binding BoardVersion}" />
            <Label Grid.Row="5" Text="Vendor / product" FontAttributes="Bold" />
            <Label Grid.Row="5" Grid.Column="1" Text="{Binding VendorProduct}" />
            <Label Grid.Row="6" Text="UID / UID2" FontAttributes="Bold" />
            <VerticalStackLayout Grid.Row="6" Grid.Column="1">
                <Label Text="{Binding HardwareUid}" />
                <Label Text="{Binding HardwareUid2}" />
            </VerticalStackLayout>
            <Label Grid.Row="7" Text="MAVLink version" FontAttributes="Bold" />
            <Label Grid.Row="7" Grid.Column="1" Text="{Binding MavLinkVersion}" />
            <Label Grid.Row="8" Text="Capabilities" FontAttributes="Bold" />
            <Label Grid.Row="8" Grid.Column="1" Text="{Binding Capabilities}" LineBreakMode="WordWrap" />
        </Grid>

        <Label Text="Firmware discovery" FontSize="18" FontAttributes="Bold" />
        <HorizontalStackLayout Spacing="10">
            <Picker Title="Channel"
                    ItemsSource="{Binding Channels}"
                    SelectedItem="{Binding SelectedChannel}" />
            <Button BackgroundColor="Transparent"
                    FontSize="14"
                    Text="Discover compatible releases"
                    Command="{Binding DiscoverCommand}" />
        </HorizontalStackLayout>
        <Picker Title="Compatible release (exact board IDs)"
                ItemsSource="{Binding Releases}"
                SelectedItem="{Binding SelectedRelease}"
                ItemDisplayBinding="{Binding Version}" />
        <Label Text="{Binding SelectedBoardTarget, StringFormat='Technical board target: {0}'}" FontAttributes="Bold" />
        <Label Text="{Binding SelectedReleaseNotes}" LineBreakMode="WordWrap" />
        <HorizontalStackLayout Spacing="10">
            <Button BackgroundColor="Transparent"
                    FontSize="14"
                    Text="Download and verify"
                    Command="{Binding DownloadCommand}" />
            <Button BackgroundColor="Transparent"
                    FontSize="14"
                    Text="Flash verified package"
                    Command="{Binding FlashCommand}" />
        </HorizontalStackLayout>
        <Label Text="{Binding Status}" FontAttributes="Italic" LineBreakMode="WordWrap" />
        <Label Text="{Binding FlashingAvailability}" LineBreakMode="WordWrap" />
        <Label Text="After flashing: reconnect, confirm the reported firmware identity, then restore only reviewed parameters from your backup."
               LineBreakMode="WordWrap"
               FontAttributes="Bold" />
    </VerticalStackLayout>
</ContentView>
