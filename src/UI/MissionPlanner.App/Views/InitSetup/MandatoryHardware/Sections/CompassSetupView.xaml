<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:sections="clr-namespace:MissionPlanner.App.Views.InitSetup.MandatoryHardware.Sections"
             x:Class="MissionPlanner.App.Views.InitSetup.MandatoryHardware.Sections.CompassSetupView"
             x:DataType="sections:CompassSetupViewModel">
    <VerticalStackLayout Spacing="10">
        <Label Text="Compass discovery and calibration" FontSize="18" FontAttributes="Bold" />
        <Label Text="{Binding Status}" FontAttributes="Italic" LineBreakMode="WordWrap" />
        <VerticalStackLayout IsVisible="{Binding HasIssues}" Spacing="4">
            <Label Text="Configuration warnings" FontAttributes="Bold" TextColor="OrangeRed" />
            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Issues}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <Label Text="{Binding .}" TextColor="OrangeRed" LineBreakMode="WordWrap" />
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </VerticalStackLayout>
        <VerticalStackLayout BindableLayout.ItemsSource="{Binding Compasses}" Spacing="8">
            <BindableLayout.ItemTemplate>
                <DataTemplate x:DataType="sections:CompassInstanceViewModel">
                    <Border Padding="10" StrokeThickness="1">
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="4" ColumnSpacing="8">
                            <Label Text="{Binding Header}" FontAttributes="Bold" />
                            <Label Grid.Column="1" Text="{Binding HealthLabel}" />
                            <Label Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding DeviceLabel}" />
                            <Label Grid.Row="2" Grid.ColumnSpan="2" Text="{Binding OffsetsLabel}" Opacity="0.75" />
                            <Label Grid.Row="3" Grid.ColumnSpan="2" Text="{Binding MotorCompensationLabel}" Opacity="0.75" />
                            <HorizontalStackLayout Grid.Row="4" Grid.ColumnSpan="2" Spacing="10">
                                <Label Text="Use" VerticalOptions="Center" />
                                <Switch IsToggled="{Binding IsUsed}" />
                                <Label Text="External" VerticalOptions="Center" IsVisible="{Binding SupportsExternal}" />
                                <Switch IsToggled="{Binding IsExternal}" IsVisible="{Binding SupportsExternal}" />
                                <Picker Title="Orientation"
                                        ItemsSource="{Binding Orientations}"
                                        SelectedItem="{Binding SelectedOrientation}"
                                        ItemDisplayBinding="{Binding Name}" />
                                <Button BackgroundColor="Transparent"
                                        FontSize="14"
                                        Text="Write and verify"
                                        Command="{Binding ApplyCommand}" />
                            </HorizontalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </BindableLayout.ItemTemplate>
        </VerticalStackLayout>
        <Button BackgroundColor="Transparent"
                FontSize="14"
                Text="Refresh compass values"
                Command="{Binding RefreshInventoryCommand}"
                HorizontalOptions="Start" />

        <Label Text="Onboard calibration" FontSize="18" FontAttributes="Bold" />
        <Label Text="Move away from metal, vehicles, and magnetic interference before starting calibration."
               TextColor="OrangeRed"
               FontAttributes="Bold"
               LineBreakMode="WordWrap" />
        <Label Text="{Binding CalibrationState, StringFormat='State: {0}'}" FontAttributes="Bold" />
        <Label Text="{Binding Instruction}" FontSize="17" FontAttributes="Bold" LineBreakMode="WordWrap" />
        <Label Text="{Binding ProgressSummary}" LineBreakMode="WordWrap" />
        <Label Text="{Binding QualitySummary}" FontAttributes="Italic" LineBreakMode="WordWrap" />
        <HorizontalStackLayout Spacing="10">
            <Button BackgroundColor="Transparent" FontSize="14" Text="Start calibration" IsEnabled="{Binding CanStart}" Command="{Binding StartCalibrationCommand}" />
            <Button BackgroundColor="Transparent" FontSize="14" Text="Accept results" IsEnabled="{Binding CanAccept}" Command="{Binding AcceptCalibrationCommand}" />
            <Button BackgroundColor="Transparent" FontSize="14" Text="Cancel calibration" IsEnabled="{Binding CanCancel}" Command="{Binding CancelCalibrationCommand}" />
            <Button BackgroundColor="Transparent" FontSize="14" Text="Reset / retry" IsEnabled="{Binding CanStart}" Command="{Binding ResetCommand}" />
        </HorizontalStackLayout>
    </VerticalStackLayout>
</ContentView>
