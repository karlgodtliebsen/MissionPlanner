<?xml version="1.0" encoding="utf-8" ?>
<uranium:UraniumContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                            xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                            xmlns:uranium="http://schemas.enisn-projects.io/dotnet/maui/uraniumui"
                            xmlns:sections="clr-namespace:MissionPlanner.App.Views.InitSetup.MandatoryHardware.Sections"
                            xmlns:mandatoryHardware="clr-namespace:MissionPlanner.App.Views.InitSetup.MandatoryHardware"
                            x:Class="MissionPlanner.App.Views.InitSetup.MandatoryHardware.MandatoryHardwareView"
                            x:DataType="mandatoryHardware:MandatoryHardwareViewModel"
                            x:Name="RootPage"
                            Title="Initial Setup">
    <Grid Padding="20" RowDefinitions="Auto,Auto,190,*" RowSpacing="14">
        <VerticalStackLayout Spacing="4">
            <Label Text="Initial Setup" FontSize="26" FontAttributes="Bold" />
            <Label Text="{Binding VehicleHeading}" FontSize="16" />
            <Label Text="{Binding SummaryReport}" Opacity="0.75" />
            <Label Text="{Binding Error}" TextColor="Red" />
        </VerticalStackLayout>

        <Button Grid.Row="1"
                BackgroundColor="Transparent"
                FontSize="14"
                Text="Re-evaluate vehicle"
                Command="{Binding RefreshCommand}"
                HorizontalOptions="Start" />

        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Workflows}"
                        SelectedItem="{Binding SelectedWorkflow, Mode=TwoWay}"
                        SelectionMode="Single">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="sections:SetupWorkflowItemViewModel">
                    <Border WidthRequest="290" Padding="14" StrokeThickness="1">
                        <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="5">
                            <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="16" />
                            <Label Grid.Column="1" Text="{Binding StateDisplay}" FontAttributes="Bold" />
                            <Label Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding Description}" LineBreakMode="WordWrap" />
                            <Label Grid.Row="2" Grid.ColumnSpan="2" Text="{Binding StatusText}" Opacity="0.72" LineBreakMode="WordWrap" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <ScrollView Grid.Row="3">
            <VerticalStackLayout Spacing="14" BindableLayout.EmptyView="Select a setup workflow.">
                <Label Text="{Binding SelectedWorkflow.Title}" FontSize="24" FontAttributes="Bold" />
                <Label Text="{Binding SelectedWorkflow.Description}" FontSize="16" LineBreakMode="WordWrap" />
                <Label Text="{Binding SelectedWorkflow.StatusText}" FontAttributes="Italic" />

                <sections:FirmwareSetupView x:Name="FirmwareSectionView"
                                            IsVisible="{Binding BindingContext.IsFirmwareSelected, Source={x:Reference RootPage}}" />
                <sections:FrameSetupView x:Name="FrameSectionView"
                                         IsVisible="{Binding BindingContext.IsFrameSelected, Source={x:Reference RootPage}}" />
                <sections:AccelerometerSetupView x:Name="AccelerometerSectionView"
                                                 IsVisible="{Binding BindingContext.IsAccelerometerSelected, Source={x:Reference RootPage}}" />
                <sections:CompassSetupView x:Name="CompassSectionView"
                                           IsVisible="{Binding BindingContext.IsCompassSelected, Source={x:Reference RootPage}}" />
                <sections:RadioSetupView x:Name="RadioSectionView"
                                         IsVisible="{Binding BindingContext.IsRadioSelected, Source={x:Reference RootPage}}" />
                <sections:FlightModesSetupView x:Name="FlightModesSectionView"
                                               IsVisible="{Binding BindingContext.IsFlightModesSelected, Source={x:Reference RootPage}}" />
                <sections:BatterySetupView x:Name="BatterySectionView"
                                           IsVisible="{Binding BindingContext.IsBatterySelected, Source={x:Reference RootPage}}" />
                <sections:EscMotorSetupView x:Name="EscMotorSectionView"
                                            IsVisible="{Binding BindingContext.IsEscSelected, Source={x:Reference RootPage}}" />
                <sections:ServoOutputSetupView x:Name="ServoOutputSectionView"
                                               IsVisible="{Binding BindingContext.IsServoOutputSelected, Source={x:Reference RootPage}}" />
                <sections:OptionalHardwareSetupView x:Name="OptionalHardwareSectionView"
                                                    IsVisible="{Binding BindingContext.IsOptionalHardwareSelected, Source={x:Reference RootPage}}" />
                <sections:SafetySetupView x:Name="SafetySectionView"
                                          IsVisible="{Binding BindingContext.IsSafetySelected, Source={x:Reference RootPage}}" />
                <sections:SetupSummaryView x:Name="SummarySectionView"
                                           IsVisible="{Binding BindingContext.IsSummarySelected, Source={x:Reference RootPage}}" />

                <HorizontalStackLayout Spacing="10">
                    <Button BackgroundColor="Transparent"
                            FontSize="14"
                            Text="Record reviewed"
                            IsEnabled="{Binding SelectedWorkflow.CanOpen}"
                            IsVisible="{Binding CanRecordSelectedWorkflowManually}"
                            Command="{Binding MarkCompleteCommand}" />
                    <Button BackgroundColor="Transparent"
                            FontSize="14"
                            Text="Open related Config page"
                            IsVisible="{Binding HasConfigDestination}"
                            Command="{Binding OpenConfigCommand}" />
                </HorizontalStackLayout>
                <Label Text="Completion is stored locally and automatically requires review when firmware or parameters change. Prerequisites are guidance, not a rigid wizard."
                       LineBreakMode="WordWrap"
                       Opacity="0.7" />
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</uranium:UraniumContentPage>
