<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:sections="clr-namespace:MissionPlanner.App.Views.InitSetup.MandatoryHardware.Sections"
             x:Class="MissionPlanner.App.Views.InitSetup.MandatoryHardware.Sections.EscMotorSetupView"
             x:DataType="sections:EscMotorSetupViewModel">
    <VerticalStackLayout Spacing="10">
        <Label Text="ESC calibration and motor test" FontSize="18" FontAttributes="Bold" />
        <Label Text="Remove ALL propellers before any actuator test. Motors will spin."
               TextColor="OrangeRed"
               FontAttributes="Bold"
               LineBreakMode="WordWrap" />
        <Label Text="{Binding EscExplanation}" LineBreakMode="WordWrap" />
        <VerticalStackLayout IsVisible="{Binding EscCalibrationApplicable}"
                             BindableLayout.ItemsSource="{Binding EscSteps}">
            <BindableLayout.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                    <Label Text="{Binding .}" LineBreakMode="WordWrap" />
                </DataTemplate>
            </BindableLayout.ItemTemplate>
        </VerticalStackLayout>
        <VerticalStackLayout IsVisible="{Binding SupportsMotorTest}" Spacing="6">
            <Label Text="Motor test" FontSize="16" FontAttributes="Bold" />
            <Grid ColumnDefinitions="120,*,120,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="6">
                <Label Text="Motor / count" VerticalOptions="Center" />
                <Entry Grid.Column="1" Text="{Binding MotorIndex}" Keyboard="Numeric" />
                <Label Grid.Column="2" Text="Throttle %" VerticalOptions="Center" />
                <Entry Grid.Column="3" Text="{Binding ThrottlePercent}" Keyboard="Numeric" />
                <Label Grid.Row="1" Text="Duration (s)" VerticalOptions="Center" />
                <Entry Grid.Row="1" Grid.Column="1" Text="{Binding DurationSeconds}" Keyboard="Numeric" />
            </Grid>
            <Label Text="{Binding Instruction}" FontAttributes="Bold" LineBreakMode="WordWrap" />
            <HorizontalStackLayout Spacing="10">
                <Button BackgroundColor="Transparent" FontSize="14" Text="Test motor" Command="{Binding TestMotorCommand}" />
                <Button BackgroundColor="Transparent" FontSize="14" Text="Test sequence" Command="{Binding TestSequenceCommand}" />
                <Button BackgroundColor="Transparent" FontSize="14" TextColor="OrangeRed" FontAttributes="Bold" Text="STOP" Command="{Binding StopCommand}" />
            </HorizontalStackLayout>
            <Label Text="Operation log" FontAttributes="Bold" />
            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Log}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <Label Text="{Binding .}" FontSize="12" Opacity="0.8" />
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </VerticalStackLayout>
</ContentView>
