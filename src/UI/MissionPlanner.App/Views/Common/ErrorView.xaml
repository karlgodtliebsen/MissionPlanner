<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
              xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:common="clr-namespace:MissionPlanner.App.Views.Common"
              x:Class="MissionPlanner.App.Views.Common.ErrorView"
              x:DataType="common:ErrorViewModel"
              HorizontalOptions="Center"
              VerticalOptions="Center"
              BackgroundColor="#80000000">


        <VerticalStackLayout  Margin="25,50,25,50" Padding="50" HorizontalOptions="Center" VerticalOptions="Center">

            <Label Background="Transparent" HorizontalOptions="Center" VerticalOptions="Center"  FontSize="16" Text="{Binding ErrorMessage}"></Label>
            
        </VerticalStackLayout>

</ContentView>
