<?xml version="1.0" encoding="utf-8" ?>
<tabs:ContentPageView x:TypeArguments="tabs:FullParametersListTabViewModel"
                      xmlns:tabs="clr-namespace:MissionPlanner.App.Views.ConfigTuning.Tabs"
                      xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                      xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                      xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
                      xmlns:m="http://schemas.enisn-projects.io/dotnet/maui/uraniumui"
                      xmlns:controls="clr-namespace:InputKit.Shared.Controls;assembly=InputKit.Maui"
                      xmlns:configTuning="clr-namespace:MissionPlanner.App.Views.ConfigTuning"
                      x:Class="MissionPlanner.App.Views.ConfigTuning.Tabs.FullParametersListTabView"
                      x:DataType="tabs:FullParametersListTabViewModel">

    <tabs:ContentPageView.Content>

        <Grid RowDefinitions="Auto,Auto,Auto,*"
          HorizontalOptions="Fill"
          VerticalOptions="Fill"
          Padding="8,0"
          BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}"
          >

            <HorizontalStackLayout Grid.Row="0" HeightRequest="50" HorizontalOptions="Fill" VerticalOptions="Center" Padding="8,0" Spacing="12" >
                <Button 
                Text="Load from file"
                    FontSize="14"
                    Padding="8,4"
                    VerticalOptions="Center"
                    BackgroundColor="Transparent"
                    Command="{Binding LoadFromFileCommand}" />

                <Button 
                Text="Save to file"
                FontSize="14"
                Padding="8,4"
                VerticalOptions="Center"
                BackgroundColor="Transparent"
                Command="{Binding SaveToFileCommand}" />
                <Button 
                    Text="Load from json file"
                    FontSize="14"
                    Padding="8,4"
                    VerticalOptions="Center"
                    BackgroundColor="Transparent"
                    Command="{Binding LoadFromJsonFileCommand}" />

                <Button 
                    Text="Save to json file"
                    FontSize="14"
                    Padding="8,4"
                    VerticalOptions="Center"
                    BackgroundColor="Transparent"
                    Command="{Binding SaveToJsonFileCommand}" />

                <Button 
                Text="Apply modified"
                FontSize="14"
                Padding="8,4"
                VerticalOptions="Center"
                BackgroundColor="Transparent"
                Command="{Binding WriteParametersCommand}" />

                <Button 
                    Text="Refresh Params"
                    FontSize="14"
                    Padding="8,4"
                    VerticalOptions="Center"
                    BackgroundColor="Transparent"
                    Command="{Binding RefreshParametersCommand}" />

                <Button 
                    Text="Compare Params"
                    FontSize="14"
                    Padding="8,4"
                    VerticalOptions="Center"
                    BackgroundColor="Transparent"
                    Command="{Binding CompareParametersCommand}" />

                <Button 
                Text="Cancel"
                FontSize="14"
                Padding="8,4"
                VerticalOptions="Center"
                BackgroundColor="Transparent"
                Command="{Binding CancelLoadCommand}" />

                <Button 
                Text="Load Pre saved"
                FontSize="14"
                Padding="8,4"
                VerticalOptions="Center"
                BackgroundColor="Transparent"
                Command="{Binding LoadPreSavedCommand}" />


                <Button 
                Text="Revert changes"
                FontSize="14"
                Padding="8,4"
                VerticalOptions="Center"
                BackgroundColor="Transparent"
                Command="{Binding ResetToDefaultCommand}" />


            </HorizontalStackLayout>

            <!-- Search and Status Bar -->
            <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" Padding="8,8" ColumnSpacing="12" >
                <Label Grid.Column="0" Text="Search:" VerticalOptions="Center" FontSize="14" />
                <Entry Grid.Column="1"
                   Text="{Binding SearchText}"
                   Placeholder="Search by name or description..."
                   VerticalOptions="Center"
                   FontSize="14" />
                <HorizontalStackLayout Grid.Column="2" Spacing="16" VerticalOptions="Center">
                    <Label VerticalOptions="Center" FontSize="14">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="Modified: " />
                                <Span Text="{Binding ModifiedParameterCount}" FontAttributes="Bold" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                    <Label VerticalOptions="Center" FontSize="14">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="Total: " />
                                <Span Text="{Binding TotalParameterCount}" FontAttributes="Bold" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </HorizontalStackLayout>
            </Grid>

            <HorizontalStackLayout Grid.Row="2" Padding="8,4" Spacing="12">
                <Label TextColor="OrangeRed" Text="{Binding ErrorMessage}" LineBreakMode="WordWrap" VerticalOptions="Center" />
                <Label Text="{Binding StatusMessage}" LineBreakMode="WordWrap" VerticalOptions="Center" />
                <Label Text="Reboot required after confirmed changes"
                       IsVisible="{Binding RebootRequired}"
                       TextColor="OrangeRed"
                       FontAttributes="Bold"
                       VerticalOptions="Center" />
            </HorizontalStackLayout>

            <Grid Grid.Row="3" VerticalOptions="Fill" HorizontalOptions="Fill" Padding="10">

                <ScrollView HorizontalScrollBarVisibility="Default" VerticalScrollBarVisibility="Always" HorizontalOptions="Fill"
                            VerticalOptions="Fill"
                             Padding="10"
                    >
                    <!--IsVisible="{Binding ShowDataGrid}"-->


                    <material:DataGrid 
                    ItemsSource="{Binding Parameters}"
                    UseAutoColumns="False"
                    VerticalOptions="Fill"
                    HorizontalOptions="Fill"
                    
                    Margin="8" >

                        <!--IsVisible="{Binding ShowEmptyView}"-->

                        <material:DataGrid.EmptyView > 
                            <VerticalStackLayout  VerticalOptions="Center" HorizontalOptions="Center" >
                                <Image
                        WidthRequest="40"
                        HeightRequest="40"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        Source="{FontImageSource FontFamily=MaterialOutlined, Glyph={x:Static m:MaterialOutlined.Backup_table}, 
                                    Color={AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}}"/>
                                <Label Text="No data available..." VerticalOptions="Center" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </material:DataGrid.EmptyView>


                        <material:DataGrid.Columns>
                            <material:DataGridColumn Title="Param" >
                                <material:DataGridColumn.CellItemTemplate >
                                    <DataTemplate  x:DataType="configTuning:ParameterItemViewModel" >
                                        <VerticalStackLayout HorizontalOptions="Fill" VerticalOptions="Center" Margin="10,0,10,0">
                                            <Label VerticalOptions="Center" VerticalTextAlignment="Center" 
                                                   HorizontalOptions="Start" HorizontalTextAlignment="Start" Text="{Binding Name}"/>

                                        </VerticalStackLayout>
                                    </DataTemplate>
                                </material:DataGridColumn.CellItemTemplate>
                            </material:DataGridColumn>

                            <material:DataGridColumn Title="Value" >
                                <material:DataGridColumn.CellItemTemplate >
                                    <DataTemplate  x:DataType="configTuning:ParameterItemViewModel" >
                                        <VerticalStackLayout HorizontalOptions="Fill" VerticalOptions="Center" Margin="10,0,10,0">
                                            <material:EditorField FontSize="16" WidthRequest="100"  IsReadOnly="{Binding IsReadOnly}"
                                                                  Keyboard="Numeric"
                                                                  HorizontalOptions="End" VerticalOptions="Center"  
                                                                  Text="{Binding Value, Mode=TwoWay}"
                                            />
                                            <Label Text="{Binding ValidationError}" TextColor="OrangeRed" FontSize="11"
                                                   IsVisible="{Binding IsModified}" LineBreakMode="WordWrap" />
                                        </VerticalStackLayout>
                                    </DataTemplate>
                                </material:DataGridColumn.CellItemTemplate>
                            </material:DataGridColumn>

                            <material:DataGridColumn  Width="225"  Title="Selections">
                                <material:DataGridColumn.CellItemTemplate>
                                    <DataTemplate  x:DataType="configTuning:ParameterItemViewModel">
                                        <VerticalStackLayout HorizontalOptions="Fill" VerticalOptions="Center" Margin="10,5,10,5">
                                            <material:PickerField IsVisible="{Binding HasValuesData}"
                                                                  FontSize="16" 
                                                                  Title="Pick an option"
                                                                  TitleFontSize="10"
                                                                  WidthRequest="225" VerticalOptions="Center" HorizontalOptions="Fill"
                                                                  ItemsSource="{Binding ValuesData}"
                                                                  SelectedItem="{Binding SelectedValue}" />


                                            <material:MultiplePickerField  IsVisible="{Binding HasBitmask}"
                                                                           Title="Multiple options"
                                                                           TitleFontSize="10"
                                                                           WidthRequest="225" VerticalOptions="Center" HorizontalOptions="Fill"
                                                                           ItemsSource="{Binding BitmaskOptions}" 
                                                                           SelectedValuesChangedCommand="{Binding SelectedValuesChanged}"
                                                                           SelectedItems="{Binding SelectedBitmaskItems}" />


                                            <Grid ColumnDefinitions="*,Auto,Auto" WidthRequest="225" IsVisible="{Binding HasNumericRangeData}"  
                                                  VerticalOptions="Fill" HorizontalOptions="Fill">
                                                <material:EditorField FontSize="16"  Grid.Column="0" 
                                                                      Keyboard="Numeric"
                                                                      Title="Number"
                                                                      TitleFontSize="10"
                                                                      HorizontalOptions="Fill" VerticalOptions="Center"  
                                                                      Text="{Binding Value, Mode=TwoWay}"
                                                />

                                                <Button Background="LightGray"
                                                        BorderColor="Transparent"
                                                        TextColor="Black"
                                                        Text="-"
                                                        FontSize="22"
                                                        Margin="0,3,0,0" Grid.Column="1"  HorizontalOptions="Fill" VerticalOptions="Fill"  
                                                        Command="{Binding DecrementNumberCommand}" />
                                                <Button Background="LightGray" 
                                                        BorderColor="Transparent"
                                                        TextColor="Black"
                                                        FontSize="22"
                                                        Text="+"
                                                        Margin="0,4,0,0"  Grid.Column="2"  HorizontalOptions="Fill" VerticalOptions="Fill"  
                                                        Command="{Binding IncrementNumberCommand}" />
                                            </Grid>
                                        </VerticalStackLayout>
                                    </DataTemplate>
                                </material:DataGridColumn.CellItemTemplate>
                            </material:DataGridColumn>

                            <!--<material:DataGridColumn  Width="125"  ValueBinding="{Binding Range}" Title="Range"  />-->
                            <!--<material:DataGridColumn  Width="125"  ValueBinding="{Binding OriginalValue}" Title="Default"  />-->
                            <material:DataGridColumn Width="125" Title="Units">
                                <material:DataGridColumn.CellItemTemplate>
                                    <DataTemplate x:DataType="configTuning:ParameterItemViewModel">
                                        <Label Text="{Binding Units}" Margin="10,0" VerticalOptions="Center" />
                                    </DataTemplate>
                                </material:DataGridColumn.CellItemTemplate>
                            </material:DataGridColumn>
                           
                            
                            <!--<material:DataGridColumn Width="130" Title="Write status">
                                <material:DataGridColumn.CellItemTemplate>
                                    <DataTemplate x:DataType="configTuning:ParameterItemViewModel">
                                        <VerticalStackLayout Margin="10,4" VerticalOptions="Center">
                                            <Label Text="{Binding WriteStatus}" />
                                            <Label Text="{Binding WriteMessage}" FontSize="10" LineBreakMode="WordWrap" />
                                        </VerticalStackLayout>
                                    </DataTemplate>
                                </material:DataGridColumn.CellItemTemplate>
                            </material:DataGridColumn>-->


                            <!--<material:DataGridColumn Title="Options" Width="125" >
                                <material:DataGridColumn.CellItemTemplate>
                                    <DataTemplate  x:DataType="configTuning:ParameterItemViewModel">
                                        <VerticalStackLayout HorizontalOptions="Fill" VerticalOptions="Fill" Margin="0,0,0,0">
                                            <Label FontSize="12" VerticalOptions="Center" VerticalTextAlignment="Center" LineBreakMode="MiddleTruncation"  
                                                   HorizontalOptions="Start" HorizontalTextAlignment="Start" Text="{Binding Options}"/>
                                        </VerticalStackLayout>
                                    </DataTemplate>
                                </material:DataGridColumn.CellItemTemplate>
                            </material:DataGridColumn>-->
                            <material:DataGridColumn Title="Description" Width="*">
                                <material:DataGridColumn.CellItemTemplate>
                                    <DataTemplate  x:DataType="configTuning:ParameterItemViewModel">

                                        <VerticalStackLayout HorizontalOptions="Fill" VerticalOptions="Fill" Margin="10,10,0,10">
                                            <Label FontSize="12" VerticalOptions="Center" VerticalTextAlignment="Center" LineBreakMode="WordWrap"  
                                                   HorizontalOptions="Start" HorizontalTextAlignment="Start" Text="{Binding DisplayName}"/>
                                            <Label FontSize="12" VerticalOptions="Fill" 
                                                   HorizontalOptions="Fill"  Text=" "/>
                                            <Label FontSize="12" VerticalOptions="Center" VerticalTextAlignment="Center" LineBreakMode="WordWrap"  
                                                   HorizontalOptions="Start" HorizontalTextAlignment="Start" Text="{Binding Description}"/>
                                        </VerticalStackLayout>
                                    </DataTemplate>
                                </material:DataGridColumn.CellItemTemplate>
                            </material:DataGridColumn>

                        </material:DataGrid.Columns>
                    </material:DataGrid>
                </ScrollView>
            </Grid>

        </Grid>

    </tabs:ContentPageView.Content>

</tabs:ContentPageView>      
