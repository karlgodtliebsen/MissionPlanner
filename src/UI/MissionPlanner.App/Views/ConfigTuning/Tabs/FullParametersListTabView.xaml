                                    <Label VerticalOptions="Center" MaximumHeightRequest="40" HorizontalOptions="Start" Text="{Binding Units}" />
                                </DataTemplate>
                            </material:DataGridColumn.CellItemTemplate>
                        </material:DataGridColumn>

                        <material:DataGridColumn Title="Options">
                            <material:DataGridColumn.CellItemTemplate>
