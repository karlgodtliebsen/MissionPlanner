<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
              xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
              xmlns:tabs="clr-namespace:MissionPlanner.App.Views.FlightData.Tabs"
              xmlns:tabs1="clr-namespace:MissionPlanner.App.Views.ConfigTuning.Tabs"
              x:Class="MissionPlanner.App.Views.ConfigTuning.Tabs.FullParametersListTabView"
              x:DataType="tabs1:FullParametersListTabViewModel">

    <Grid RowDefinitions="Auto,*" 
          HorizontalOptions="Fill"
          VerticalOptions="Fill"
          Padding="8,0" 
          BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}"
          >

        <HorizontalStackLayout Grid.Row="0" HeightRequest="50" HorizontalOptions="Fill" VerticalOptions="Center" Padding="8,0" Spacing="12" >

            <!--<Label Text="{Binding ProgressMessage}" />-->
            <!--
            <Label Text="{Binding CountMessage}" />
            <Label Text="{Binding TotalCountMessage}" />
            -->

            <Button 
                Text="Load from file"
                    FontSize="14"
                    Padding="8,4"
                    VerticalOptions="Center"
                    BackgroundColor="Transparent"
                    Command="{Binding LoadFromFileCommand}" />

            <Button 
                Text="Save to file"
                FontSize="14"
                Padding="8,4"
                VerticalOptions="Center"
                BackgroundColor="Transparent"
                Command="{Binding SaveToFileCommand}" />

            <Button 
                Text="Write Params"
                FontSize="14"
                Padding="8,4"
                VerticalOptions="Center"
                BackgroundColor="Transparent"
                Command="{Binding WriteParametersCommand}" />




            <Button 
                Text="Refresh Params"
                FontSize="14"
                Padding="8,4"
                VerticalOptions="Center"
                BackgroundColor="Transparent"
                Command="{Binding RefreshParametersCommand}" />

            <Button 
                Text="Compare Params"
                FontSize="14"
                Padding="8,4"
                VerticalOptions="Center"
                BackgroundColor="Transparent"
                Command="{Binding CompareParametersCommand}" />

            <Button 
                Text="Cancel"
                FontSize="14"
                Padding="8,4"
                VerticalOptions="Center"
                BackgroundColor="Transparent"
                Command="{Binding CancelLoadCommand}" />

            <Button 
                Text="Load Pre saved"
                FontSize="14"
                Padding="8,4"
                VerticalOptions="Center"
                BackgroundColor="Transparent"
                Command="{Binding LoadPreSavedCommand}" />


            <Button 
                Text="Reset to Default"
                FontSize="14"
                Padding="8,4"
                VerticalOptions="Center"
                BackgroundColor="Transparent"
                Command="{Binding ResetToDefaultCommand}" />


        </HorizontalStackLayout>

        <VerticalStackLayout Padding="20" Spacing="12"  Grid.Row="1" VerticalOptions="Center" HorizontalOptions="Center"
        >
            <VerticalStackLayout Padding="20" Spacing="12"  Grid.Row="1" VerticalOptions="Center" HorizontalOptions="Center" IsVisible="{Binding ShowLoading}"
                            >
                <Label FontSize="16"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" Text="{Binding ProgressMessage}" />
                <ProgressBar Progress="{Binding Progress}" />
            </VerticalStackLayout>

            <Label FontSize="16"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" 
                   IsVisible="{Binding ShowLoadingCompleted}"
                   Text="Finished loading params" />
            <Label FontSize="16"
                   IsVisible="{Binding ShowLoadingCompletedWithError}"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" Text="An Error Occurred loading params" />
            <Label FontSize="16"
                   IsVisible="{Binding ShowLoadingCancelled}"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" Text="Loading cancelled" />

        </VerticalStackLayout>

    </Grid>
</ContentView>
