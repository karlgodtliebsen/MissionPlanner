{
  "Logging": {
    "LogLevel": {
      "Default": "Information"
    }
  },
  "ApplicationInformation": {
    "AppName": "MissionPlanner Application"
  },

  "ApplicationSettings": {
    "Ports": [
      "AUTO",
      "TCP",
      "UDP",
      "UDPCI",
      "WS"
    ],
    "BaudRates": [
      "4800",
      "9600",
      "19200",
      "38400",
      "57600",
      "115200",
      "230400",
      "460800",
      "921600"
    ],
    "Port": "AUTO",
    "BaudRate": "115200"
  },  

  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Verbose",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "./logs/MissionPlanner.NextGen.Application..log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 2,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] ({ThreadId}/{TraceId}/{SpanId}) {Message:lj}{NewLine}{Exception}",
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithTraceIdentifier", "WithSpan", "WithSpanId", "WithThreadId", "WithExceptionDetails" ],
    "Properties": {
      "Application": "MissionPlanner NextGen Application"
    }
  }
}
