<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:tabs="clr-namespace:MissionPlanner.App.Views.ConfigTuning.Tabs"
             xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
             xmlns:m="http://schemas.enisn-projects.io/dotnet/maui/uraniumui"
             xmlns:controls="clr-namespace:InputKit.Shared.Controls;assembly=InputKit.Maui"
             xmlns:configTuning="clr-namespace:MissionPlanner.App.Views.ConfigTuning"
             x:Class="MissionPlanner.App.Views.ConfigTuning.Tabs.FullParametersListTabView"
             x:DataType="tabs:FullParametersListTabViewModel">

    <ContentPage.Content>

        <Grid RowDefinitions="Auto,Auto,Auto,*"
          HorizontalOptions="Fill"
          VerticalOptions="Fill"
          Padding="8,0"
          BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}"
          >

            <HorizontalStackLayout Grid.Row="0" HeightRequest="50" HorizontalOptions="Fill" VerticalOptions="Center" Padding="8,0" Spacing="12" >
                <Button 
                Text="Load from file"
                    FontSize="14"
                    Padding="8,4"
                    VerticalOptions="Center"
                    BackgroundColor="Transparent"
                    Command="{Binding LoadFromFileCommand}" />

                <Button 
                Text="Save to file"
                FontSize="14"
                Padding="8,4"
                VerticalOptions="Center"
                BackgroundColor="Transparent"
                Command="{Binding SaveToFileCommand}" />
                <Button 
                    Text="Load from json file"
                    FontSize="14"
                    Padding="8,4"
                    VerticalOptions="Center"
                    BackgroundColor="Transparent"
                    Command="{Binding LoadFromJsonFileCommand}" />

                <Button 
                    Text="Save to json file"
                    FontSize="14"
                    Padding="8,4"
                    VerticalOptions="Center"
                    BackgroundColor="Transparent"
                    Command="{Binding SaveToJsonFileCommand}" />

                <Button 
                Text="Write Params"
                FontSize="14"
                Padding="8,4"
                VerticalOptions="Center"
                BackgroundColor="Transparent"
                Command="{Binding WriteParametersCommand}" />

                <Button 
                    Text="Load Metadata"
                    FontSize="14"
                    Padding="8,4"
                    VerticalOptions="Center"
                    BackgroundColor="Transparent"
                    Command="{Binding LoadMetaDataCommand}" />
                <Button 
                    Text="Refresh Params"
                    FontSize="14"
                    Padding="8,4"
                    VerticalOptions="Center"
                    BackgroundColor="Transparent"
                    Command="{Binding RefreshParametersCommand}" />

                <Button 
                    Text="Compare Params"
                    FontSize="14"
                    Padding="8,4"
                    VerticalOptions="Center"
                    BackgroundColor="Transparent"
                    Command="{Binding CompareParametersCommand}" />

                <Button 
                Text="Cancel"
                FontSize="14"
                Padding="8,4"
                VerticalOptions="Center"
                BackgroundColor="Transparent"
                Command="{Binding CancelLoadCommand}" />

                <Button 
                Text="Load Pre saved"
                FontSize="14"
                Padding="8,4"
                VerticalOptions="Center"
                BackgroundColor="Transparent"
                Command="{Binding LoadPreSavedCommand}" />


                <Button 
                Text="Reset to Default"
                FontSize="14"
                Padding="8,4"
                VerticalOptions="Center"
                BackgroundColor="Transparent"
                Command="{Binding ResetToDefaultCommand}" />


            </HorizontalStackLayout>

            <!-- Search and Status Bar -->
            <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" Padding="8,8" ColumnSpacing="12" IsVisible="{Binding ShowLoadingCompleted}">
                <Label Grid.Column="0" Text="Search:" VerticalOptions="Center" FontSize="14" />
                <Entry Grid.Column="1"
                   Text="{Binding SearchText}"
                   Placeholder="Search by name or description..."
                   VerticalOptions="Center"
                   FontSize="14" />
                <HorizontalStackLayout Grid.Column="2" Spacing="16" VerticalOptions="Center">
                    <Label VerticalOptions="Center" FontSize="14">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="Modified: " />
                                <Span Text="{Binding ModifiedParameterCount}" FontAttributes="Bold" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                    <Label VerticalOptions="Center" FontSize="14">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="Total: " />
                                <Span Text="{Binding TotalParameterCount}" FontAttributes="Bold" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </HorizontalStackLayout>
            </Grid>



            <VerticalStackLayout Grid.Row="2" Padding="20" Spacing="12" VerticalOptions="Center" HorizontalOptions="Center"
                             IsVisible="{Binding ShowLoadingPanel}"
                             
        >
                <VerticalStackLayout  Spacing="12" VerticalOptions="Center" HorizontalOptions="Center" 
                                  IsVisible="{Binding ShowLoadingProgress}">
                    <material:Chip 
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" IsDestroyVisible="False"
                                   Text="{Binding ProgressMessage}"
                    />

                    <ProgressBar Progress="{Binding Progress}" />
                </VerticalStackLayout>

                <material:Chip IsVisible="{Binding ShowLoadingCompletedWithError}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               
                               Text="An Error Occurred loading params"
                               />


                <material:Chip IsVisible="{Binding ShowLoadingCancelled}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" 
                               Text="Loading cancelled"
                               />

            </VerticalStackLayout>

            <!-- Parameter Grid -->
            <Grid Grid.Row="3" VerticalOptions="Fill" HorizontalOptions="Fill" Padding="10">

                <ScrollView HorizontalScrollBarVisibility="Default" VerticalScrollBarVisibility="Always" HorizontalOptions="Fill"
                            VerticalOptions="Fill"

                             Padding="10"

                    >

                    <material:DataGrid 
                        IsVisible="{Binding ShowDataGrid}"
                    ItemsSource="{Binding Parameters}"
                    UseAutoColumns="False"
                    VerticalOptions="Fill"
                    HorizontalOptions="Fill"
                    Margin="8" >


                        <material:DataGrid.EmptyView>
                            <VerticalStackLayout  VerticalOptions="Center" HorizontalOptions="Center" IsVisible="{Binding ShowEmptyView}">
                                <Image
                        WidthRequest="40"
                        HeightRequest="40"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        Source="{FontImageSource FontFamily=MaterialOutlined, Glyph={x:Static m:MaterialOutlined.Backup_table}, Color={AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}}"/>
                                <Label Text="No data available..." VerticalOptions="Center" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </material:DataGrid.EmptyView>


                        <material:DataGrid.Columns>
                            <material:DataGridColumn   Width="200"  ValueBinding="{Binding Name}" Title="Param"  />
                            <material:DataGridColumn Title="Value" >
                                <material:DataGridColumn.CellItemTemplate >
                                    <DataTemplate  x:DataType="configTuning:ParameterItemViewModel" >
                                        <VerticalStackLayout HorizontalOptions="Fill" VerticalOptions="Center" Margin="10,0,0,0">

                                            <Entry  Text="{Binding Value, Mode=TwoWay}" IsReadOnly="{Binding IsReadOnly}" FontSize="16"  
                                                    Keyboard="Numeric" HorizontalTextAlignment="End" 
                                                    HorizontalOptions="End" VerticalOptions="Center"  
                                                    WidthRequest="100"   />

                                        </VerticalStackLayout>
                                    </DataTemplate>
                                </material:DataGridColumn.CellItemTemplate>
                            </material:DataGridColumn>

                            <material:DataGridColumn Title="Selections">
                                <material:DataGridColumn.CellItemTemplate>
                                    <DataTemplate  x:DataType="configTuning:ParameterItemViewModel">
                                        <VerticalStackLayout HorizontalOptions="Fill" VerticalOptions="Center" Margin="10,0,0,0">
                                            <Picker IsVisible="{Binding HasValuesData}"
                                                    FontSize="16"  
                                                    WidthRequest="175"
                                                    ItemsSource="{Binding ValuesData}"
                                                    SelectedItem="{Binding SelectedValue}" />

                                           <Grid ColumnDefinitions="Auto,*,Auto"  IsVisible="{Binding HasNumericRangeData}" WidthRequest="175" VerticalOptions="Fill">
                                                <Button Background="Transparent" Margin="0,0,5,0" Grid.Column="0" Text="-"  HorizontalOptions="Center" VerticalOptions="Center"  Command="{Binding DecrementNumberCommand}" />
                                                <Entry FontSize="16" HorizontalTextAlignment="End"  Grid.Column="1" 
                                                       Keyboard="Numeric"
                                                       HorizontalOptions="Fill" VerticalOptions="Fill"  
                                                       Text="{Binding Value, Mode=TwoWay}"
                                                />
                                                <Button Background="Transparent"
                                                    Margin="5,0,0,0" Grid.Column="2" Text="+"  HorizontalOptions="Center" VerticalOptions="Center"  Command="{Binding IncrementNumberCommand}" />
                                            </Grid>

                                        </VerticalStackLayout>
                                    </DataTemplate>
                                </material:DataGridColumn.CellItemTemplate>
                            </material:DataGridColumn>

                            <material:DataGridColumn  Width="125"  ValueBinding="{Binding Range}" Title="Range"  />
                            <material:DataGridColumn  Width="125"  ValueBinding="{Binding OriginalValue}" Title="Default"  />
                            <material:DataGridColumn  Width="125"  ValueBinding="{Binding Units}" Title="Units"  />
                            <material:DataGridColumn  Width="125"  ValueBinding="{Binding Options}" Title="Options"  />
                            <material:DataGridColumn Title="Description" Width="*" >
                                <material:DataGridColumn.CellItemTemplate>
                                    <DataTemplate  x:DataType="configTuning:ParameterItemViewModel">

                                        <VerticalStackLayout HorizontalOptions="Fill" VerticalOptions="Fill" Margin="10,0,0,0">
                                            <Label VerticalOptions="Center" VerticalTextAlignment="Center" LineBreakMode="MiddleTruncation"  
                                               HorizontalOptions="Start" HorizontalTextAlignment="Start" Text="{Binding DisplayName}"/>
                                            <Label VerticalOptions="Center" VerticalTextAlignment="Center" LineBreakMode="MiddleTruncation"  
                                                   HorizontalOptions="Start" HorizontalTextAlignment="Start" Text="{Binding Description}"/>
                                        </VerticalStackLayout>
                                    </DataTemplate>
                                </material:DataGridColumn.CellItemTemplate>
                            </material:DataGridColumn>
                        </material:DataGrid.Columns>
                    </material:DataGrid>
                </ScrollView>
            </Grid>

        </Grid>

    </ContentPage.Content>

</ContentPage>
