                         <!--<material:DataGridColumn  ValueBinding="{Binding Description}" Title="Description"  />-->
                  
                    <material:DataGrid.Columns>
                        <material:DataGridColumn   ValueBinding="{Binding Name}" Title="Name"  /> 
                        <material:DataGridColumn   ValueBinding="{Binding Value}" Title="Value"  />
                        <material:DataGridColumn   ValueBinding="{Binding OriginalValue}" Title="Default"  />
                        <material:DataGridColumn   ValueBinding="{Binding Units}" Title="Units"  />
                        <material:DataGridColumn   ValueBinding="{Binding Options}" Title="Options"  />
                        <material:DataGridColumn   ValueBinding="{Binding Description}" Title="Description"  />
                    </material:DataGrid.Columns>
                    

                    <!--<material:DataGrid.Columns>
                        <material:DataGridColumn  x:DataType="vm:ParameterItemViewModel" ValueBinding="{Binding Name}" Title="Name"  /> 
                        <material:DataGridColumn  x:DataType="vm:ParameterItemViewModel" ValueBinding="{Binding OriginalValue}" Title="Default"  />
                        <material:DataGridColumn  x:DataType="vm:ParameterItemViewModel" ValueBinding="{Binding Units}" Title="Units"  />
                        <material:DataGridColumn  x:DataType="vm:ParameterItemViewModel" ValueBinding="{Binding Options}" Title="Options"  />
                        <material:DataGridColumn  x:DataType="vm:ParameterItemViewModel" ValueBinding="{Binding Description}" Title="Description"  />
                    </material:DataGrid.Columns>-->

                    <!--<material:DataGridSelectionColumn />-->
                    <!--<material:DataGridColumn  x:DataType="vm:ParameterItemViewModel" ValueBinding="{Binding Favorite}" Title="Favorite"  />-->

                </material:DataGrid>
            </Grid>

        </Grid>

    </ContentPage.Content>

</ContentPage>
