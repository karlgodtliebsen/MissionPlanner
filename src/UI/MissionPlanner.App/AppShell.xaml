<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="MissionPlanner.App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:uranium="http://schemas.enisn-projects.io/dotnet/maui/uraniumui"
    xmlns:controls="clr-namespace:InputKit.Shared.Controls;assembly=InputKit.Maui"
    xmlns:controls1="clr-namespace:Plainer.Maui.Controls;assembly=Plainer.Maui"
    xmlns:appViewModels="clr-namespace:MissionPlanner.App.AppViewModels"
    xmlns:flightData="clr-namespace:MissionPlanner.App.Views.FlightData"
    xmlns:flightPlanner="clr-namespace:MissionPlanner.App.Views.FlightPlanner"
    xmlns:initSetup="clr-namespace:MissionPlanner.App.Views.InitSetup"
    xmlns:configTuning="clr-namespace:MissionPlanner.App.Views.ConfigTuning"
    xmlns:simulation="clr-namespace:MissionPlanner.App.Views.Simulation"
    xmlns:help="clr-namespace:MissionPlanner.App.Views.Help"
    xmlns:exit="clr-namespace:MissionPlanner.App.Views.Exit"
    xmlns:tabs="clr-namespace:MissionPlanner.App.Views.ConfigTuning.Tabs"
    xmlns:common="clr-namespace:MissionPlanner.App.Views.Common"
    Title="MissionPlanner"
    x:Name="thisShell"
    FlyoutBackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}"
    Shell.FlyoutBehavior="Flyout"
    FlyoutIsPresented="False"
    >

    <!-- Persistent Top Bar (visible on all pages) -->
    <Shell.TitleView>
        <common:TopBarView />
    </Shell.TitleView>

    <Shell.Resources>
        <Style TargetType="HorizontalStackLayout" ApplyToDerivedTypes="True" CanCascade="True">
            <Setter Property="VisualStateManager.VisualStateGroups">
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal" />
                        <VisualState x:Name="Selected">
                            <VisualState.Setters>
                                <Setter Property="BackgroundColor"
                                     Value="{AppThemeBinding Light=#30000000, Dark=#30ffffff}" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </Setter>
        </Style>
    </Shell.Resources>


    <Shell.FlyoutHeader>
        <VerticalStackLayout StyleClass="PrimaryContainer" Padding="20">
            <Label Text="MissionPlanner Next Gen" FontSize="Large" HorizontalTextAlignment="Center" Margin="10" />
            <VerticalStackLayout BindingContext="{uranium:Inject Type={Type appViewModels:ThemeChangeViewModel}}" x:DataType="appViewModels:ThemeChangeViewModel">
                <Label Text="App Theme" HorizontalOptions="Center"/>
                <controls:SelectionView HorizontalOptions="Center"
                 ItemsSource="{Binding AppThemeList}" SelectedItem="{Binding SelectedTheme}" 
                 ColumnNumber="2" ColumnSpacing="-2" Color="{StaticResource Tertiary}" >
                </controls:SelectionView>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </Shell.FlyoutHeader>

    <Shell.FlyoutContent>
        <Grid RowDefinitions="Auto,*">
            <Grid.BindingContext>
                <appViewModels:AppShellContentViewModel CurrentShell="{x:Reference thisShell}"/>
            </Grid.BindingContext>
            <VerticalStackLayout>
                <VerticalStackLayout Margin="8,8,8,0" BackgroundColor="{AppThemeBinding Light={StaticResource OnSurfaceDark}, Dark={StaticResource OnSurface}}" StyleClass="Elevation1">
                    <controls1:EntryView Margin="{OnPlatform Default=0, Android='8,0', iOS='8', MacCatalyst='8'}" Placeholder="Search" Text="{Binding SearchText}" PlaceholderColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}" ClearButtonVisibility="WhileEditing"/>
                </VerticalStackLayout>
                <BoxView StyleClass="Divider" />
            </VerticalStackLayout>
            <CollectionView Grid.Row="1" SelectedItem="{Binding SelectedItem}" SelectionMode="Single" ItemsSource="{Binding Items}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <HorizontalStackLayout Padding="20,12" Spacing="12">
                            <Image Source="{Binding Icon}" WidthRequest="20" />
                            <Label Text="{Binding Title}" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </Shell.FlyoutContent>
    <FlyoutItem Title="Flight Data"  Icon="Resources/Images/x_light_flightdata_icon_x.png">
        <ShellContent
            Title=""
            ContentTemplate="{DataTemplate flightData:FlightDataView}" Route="FlightData" />
    </FlyoutItem>
    <FlyoutItem Title="Flight Plan" Icon="Resources/Images/x_light_flightplan_icon_x.png">
        <ShellContent
            Title=""
            ContentTemplate="{DataTemplate flightPlanner:FlightPlannerView}" Route="FlightPlanner" />
    </FlyoutItem>
    <FlyoutItem Title="Init Setup" Icon="Resources/Images/x_light_initialsetup_icon_x.png">
        <ShellContent
            Title=""
            ContentTemplate="{DataTemplate initSetup:InitSetupView}" Route="InitSetup" />
    </FlyoutItem>
    <FlyoutItem Title="Config"  
                Icon="Resources/Images/x_light_tuningconfig_icon_x.png">

        <ShellContent Title="Geo Fence" ContentTemplate="{DataTemplate tabs:GeoFenceTabView}"/>
        <ShellContent Title="Basic Tuning" ContentTemplate="{DataTemplate tabs:BasicTuningTabView}"/>
        <ShellContent Title="Extended Tuning" ContentTemplate="{DataTemplate tabs:ExtendedTuningTabView}"/>
        <ShellContent Title="Onboard OSD" ContentTemplate="{DataTemplate tabs:OnboardOSDTabView}"/>
        <ShellContent Title="MAV Ftp" ContentTemplate="{DataTemplate tabs:MAVFtpTabView}"/>
        <ShellContent Title="Full Parameters List" ContentTemplate="{DataTemplate tabs:FullParametersListTabView}"/>
        <ShellContent Title="Planner" ContentTemplate="{DataTemplate tabs:PlannerTabView}"/>
        <ShellContent Title="CubeLan 8 Port Switch" ContentTemplate="{DataTemplate tabs:CubeLan8PortSwitchTabView}"/>
    </FlyoutItem>

    <FlyoutItem Title="Simulation" Icon="Resources/Images/x_light_simulation_icon_x.png" >
        <ShellContent
            Title=""
            ContentTemplate="{DataTemplate simulation:SimulationView}" Route="Simulation" />
    </FlyoutItem>

    <FlyoutItem Title="Help" Icon="Resources/Images/x_light_help_icon_x.png">
        <ShellContent
            Title=""
            ContentTemplate="{DataTemplate help:HelpView}" Route="Help" />
    </FlyoutItem>

    <FlyoutItem Title="Exit" >
        <ShellContent
            Title=""
            ContentTemplate="{DataTemplate exit:ExitView}" Route="Exit" />
    </FlyoutItem>


</Shell>
