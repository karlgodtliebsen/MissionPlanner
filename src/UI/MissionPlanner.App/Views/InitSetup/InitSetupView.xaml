<?xml version="1.0" encoding="utf-8" ?>
<uranium:UraniumContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                            xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                            xmlns:uranium="http://schemas.enisn-projects.io/dotnet/maui/uraniumui"
                            xmlns:vm="clr-namespace:MissionPlanner.App.Views.InitSetup"
                            x:Class="MissionPlanner.App.Views.InitSetup.InitSetupView"
                            x:DataType="vm:InitSetupViewModel"
                            Title="Initial Setup">
    <Grid Padding="20" RowDefinitions="Auto,Auto,190,*" RowSpacing="14">
        <VerticalStackLayout Spacing="4">
            <Label Text="Initial Setup" FontSize="26" FontAttributes="Bold" />
            <Label Text="{Binding VehicleHeading}" FontSize="16" />
            <Label Text="{Binding SummaryReport}" Opacity="0.75" />
            <Label Text="{Binding Error}" TextColor="Red" />
        </VerticalStackLayout>

        <Button Grid.Row="1"
                BackgroundColor="Transparent" FontSize="14" 
                Text="Re-evaluate vehicle"
                Command="{Binding RefreshCommand}"
                HorizontalOptions="Start" />

        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Workflows}"
                            SelectedItem="{Binding SelectedWorkflow, Mode=TwoWay}"
                            SelectionMode="Single">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10" />
            </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:SetupWorkflowItemViewModel">
                        <Border WidthRequest="290" Padding="14" StrokeThickness="1">
                            <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="5">
                                <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="16" />
                                <Label Grid.Column="1" Text="{Binding StateDisplay}" FontAttributes="Bold" />
                                <Label Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding Description}" LineBreakMode="WordWrap" />
                                <Label Grid.Row="2" Grid.ColumnSpan="2" Text="{Binding StatusText}" Opacity="0.72" LineBreakMode="WordWrap" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <ScrollView Grid.Row="3">
                <VerticalStackLayout Spacing="14" BindableLayout.EmptyView="Select a setup workflow.">
                    <Label Text="{Binding SelectedWorkflowViewModel.Title}" FontSize="24" FontAttributes="Bold" />
                    <Label Text="{Binding SelectedWorkflowViewModel.Description}" FontSize="16" LineBreakMode="WordWrap" />
                    <Label Text="{Binding SelectedWorkflow.StatusText}" FontAttributes="Italic" />
                    <ProgressBar Progress="{Binding SelectedWorkflowViewModel.Progress}" />
                    <Label Text="{Binding SelectedWorkflowViewModel.Error}" TextColor="Red" />

                    <VerticalStackLayout IsVisible="{Binding IsFirmwareSelected}" Spacing="10">
                        <Label Text="Connected identity" FontSize="18" FontAttributes="Bold" />
                        <Grid ColumnDefinitions="180,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="5">
                            <Label Text="Vehicle" FontAttributes="Bold" />
                            <Label Grid.Column="1" Text="{Binding SelectedFirmwareViewModel.VehicleLabel}" />
                            <Label Grid.Row="1" Text="Firmware" FontAttributes="Bold" />
                            <Label Grid.Row="1" Grid.Column="1" Text="{Binding SelectedFirmwareViewModel.FirmwareVersion}" />
                            <Label Grid.Row="2" Text="Release type / Git" FontAttributes="Bold" />
                            <Label Grid.Row="2" Grid.Column="1" Text="{Binding SelectedFirmwareViewModel.ReleaseType, StringFormat='{0}'}" />
                            <Label Grid.Row="3" Text="Git hash" FontAttributes="Bold" />
                            <Label Grid.Row="3" Grid.Column="1" Text="{Binding SelectedFirmwareViewModel.GitHash}" />
                            <Label Grid.Row="4" Text="Board version" FontAttributes="Bold" />
                            <Label Grid.Row="4" Grid.Column="1" Text="{Binding SelectedFirmwareViewModel.BoardVersion}" />
                            <Label Grid.Row="5" Text="Vendor / product" FontAttributes="Bold" />
                            <Label Grid.Row="5" Grid.Column="1" Text="{Binding SelectedFirmwareViewModel.VendorProduct}" />
                            <Label Grid.Row="6" Text="UID / UID2" FontAttributes="Bold" />
                            <VerticalStackLayout Grid.Row="6" Grid.Column="1">
                                <Label Text="{Binding SelectedFirmwareViewModel.HardwareUid}" />
                                <Label Text="{Binding SelectedFirmwareViewModel.HardwareUid2}" />
                            </VerticalStackLayout>
                            <Label Grid.Row="7" Text="MAVLink version" FontAttributes="Bold" />
                            <Label Grid.Row="7" Grid.Column="1" Text="{Binding SelectedFirmwareViewModel.MavLinkVersion}" />
                            <Label Grid.Row="8" Text="Capabilities" FontAttributes="Bold" />
                            <Label Grid.Row="8" Grid.Column="1" Text="{Binding SelectedFirmwareViewModel.Capabilities}" LineBreakMode="WordWrap" />
                        </Grid>

                        <Label Text="Firmware discovery" FontSize="18" FontAttributes="Bold" />
                        <HorizontalStackLayout Spacing="10">
                            <Picker Title="Channel"
                                    ItemsSource="{Binding SelectedFirmwareViewModel.Channels}"
                                    SelectedItem="{Binding SelectedFirmwareViewModel.SelectedChannel}" />
                        <Button BackgroundColor="Transparent" FontSize="14" Text="Discover compatible releases"
                                Command="{Binding SelectedFirmwareViewModel.DiscoverCommand}" />
                        </HorizontalStackLayout>
                        <Picker Title="Compatible release (exact board IDs)"
                                ItemsSource="{Binding SelectedFirmwareViewModel.Releases}"
                                SelectedItem="{Binding SelectedFirmwareViewModel.SelectedRelease}"
                                ItemDisplayBinding="{Binding Version}" />
                        <Label Text="{Binding SelectedFirmwareViewModel.SelectedBoardTarget, StringFormat='Technical board target: {0}'}" FontAttributes="Bold" />
                        <Label Text="{Binding SelectedFirmwareViewModel.SelectedReleaseNotes}" LineBreakMode="WordWrap" />
                        <HorizontalStackLayout Spacing="10">
                        <Button BackgroundColor="Transparent" FontSize="14" Text="Download and verify"
                                Command="{Binding SelectedFirmwareViewModel.DownloadCommand}" />
                            <Button BackgroundColor="Transparent" FontSize="14" Text="Flash verified package"
                                    Command="{Binding SelectedFirmwareViewModel.FlashCommand}" />
                        </HorizontalStackLayout>
                        <Label Text="{Binding SelectedFirmwareViewModel.Status}" FontAttributes="Italic" LineBreakMode="WordWrap" />
                        <Label Text="{Binding SelectedFirmwareViewModel.FlashingAvailability}" LineBreakMode="WordWrap" />
                        <Label Text="After flashing: reconnect, confirm the reported firmware identity, then restore only reviewed parameters from your backup." LineBreakMode="WordWrap" FontAttributes="Bold" />
                    </VerticalStackLayout>

                    <VerticalStackLayout IsVisible="{Binding IsFrameSelected}" Spacing="10">
                        <Label Text="Supported frame configuration" FontSize="18" FontAttributes="Bold" />
                        <Label Text="{Binding SelectedFrameViewModel.FirmwareFamily, StringFormat='Firmware family: {0}'}" />
                        <Label Text="Only values advertised by the connected firmware metadata are shown. Current values remain unchanged until Write and verify is confirmed."
                               LineBreakMode="WordWrap" />
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding SelectedFrameViewModel.Settings}" Spacing="8">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="vm:FrameParameterSettingViewModel">
                                    <Border Padding="10" StrokeThickness="1">
                                        <Grid ColumnDefinitions="180,*,*" RowDefinitions="Auto,Auto" RowSpacing="4" ColumnSpacing="8">
                                            <Label Text="{Binding DisplayName}" FontAttributes="Bold" />
                                            <Label Grid.Column="1" Text="{Binding CurrentDisplay, StringFormat='Current: {0}'}" />
                                            <Picker Grid.Column="2"
                                                    Title="Pending value"
                                                    ItemsSource="{Binding Options}"
                                                    SelectedItem="{Binding SelectedOption}"
                                                    ItemDisplayBinding="{Binding Label}" />
                                            <Label Grid.Row="1" Grid.ColumnSpan="3"
                                                   Text="{Binding PendingDisplay, StringFormat='Pending: {0}'}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                        <Label IsVisible="{Binding SelectedFrameViewModel.HasRecommendations}"
                               Text="Optional initial recommendations" FontSize="18" FontAttributes="Bold" />
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding SelectedFrameViewModel.Recommendations}" Spacing="6">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="vm:FrameRecommendationViewModel">
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                        <CheckBox IsChecked="{Binding IsSelected}" />
                                        <Label Grid.Column="1" Text="{Binding Description}" LineBreakMode="WordWrap" VerticalOptions="Center" />
                                    </Grid>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                        <HorizontalStackLayout Spacing="10">
                            <Button BackgroundColor="Transparent" FontSize="14" Text="Refresh vehicle values" Command="{Binding SelectedFrameViewModel.RefreshCommand}" />
                            <Button BackgroundColor="Transparent" FontSize="14" Text="Write and verify" Command="{Binding SelectedFrameViewModel.ApplyCommand}" />
                        </HorizontalStackLayout>
                        <Label Text="{Binding SelectedFrameViewModel.Status}" FontAttributes="Italic" LineBreakMode="WordWrap" />
                        <Label IsVisible="{Binding SelectedFrameViewModel.RebootRequired}"
                               Text="Reboot required. Reconnect, then use Refresh vehicle values to confirm the persisted configuration."
                               TextColor="OrangeRed" FontAttributes="Bold" LineBreakMode="WordWrap" />
                    </VerticalStackLayout>

                    <VerticalStackLayout IsVisible="{Binding IsAccelerometerSelected}" Spacing="10">
                        <Label Text="Accelerometer and level calibration" FontSize="18" FontAttributes="Bold" />
                        <Label Text="Remove propellers. Keep the vehicle disarmed and clear of people before calibration."
                               TextColor="OrangeRed" FontAttributes="Bold" LineBreakMode="WordWrap" />
                        <HorizontalStackLayout Spacing="10">
                            <Button Text="Start six-position calibration"
                                    Command="{Binding SelectedAccelerometerViewModel.StartSixPositionCommand}" />
                            <Button Text="Calibrate level"
                                    Command="{Binding SelectedAccelerometerViewModel.StartLevelCommand}" />
                        </HorizontalStackLayout>
                        <Label Text="{Binding SelectedAccelerometerViewModel.CalibrationState, StringFormat='State: {0}'}" FontAttributes="Bold" />
                        <Label Text="{Binding SelectedAccelerometerViewModel.Instruction}" FontSize="17" FontAttributes="Bold" LineBreakMode="WordWrap" />
                        <Image Source="{Binding SelectedAccelerometerViewModel.OrientationImage}"
                               HeightRequest="260" Aspect="AspectFit" />
                        <Label Text="{Binding SelectedAccelerometerViewModel.Orientation, StringFormat='Requested orientation: {0}'}" />
                        <Label Text="{Binding SelectedAccelerometerViewModel.CompletedOrientations}" />
                        <Button BackgroundColor="Transparent" FontSize="14" Text="Confirm orientation"
                                IsEnabled="{Binding SelectedAccelerometerViewModel.CanConfirmOrientation}"
                                Command="{Binding SelectedAccelerometerViewModel.ConfirmOrientationCommand}"
                                HorizontalOptions="Start" />
                        <Label Text="{Binding SelectedAccelerometerViewModel.SupplementalStatus, StringFormat='Vehicle status: {0}'}"
                               FontAttributes="Italic" LineBreakMode="WordWrap" />
                        <HorizontalStackLayout Spacing="10">
                            <Button BackgroundColor="Transparent" FontSize="14" Text="Cancel calibration"
                                    IsEnabled="{Binding SelectedAccelerometerViewModel.CanCancel}"
                                    Command="{Binding SelectedAccelerometerViewModel.CancelCalibrationCommand}" />
                            <Button BackgroundColor="Transparent" FontSize="14" Text="Reset / retry"
                                    IsEnabled="{Binding SelectedAccelerometerViewModel.CanStart}"
                                    Command="{Binding SelectedAccelerometerViewModel.ResetCommand}" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <HorizontalStackLayout Spacing="10">
                        <Button BackgroundColor="Transparent" FontSize="14" Text="Record reviewed"
                                IsEnabled="{Binding SelectedWorkflow.CanOpen}"
                                IsVisible="{Binding CanRecordSelectedWorkflowManually}"
                                Command="{Binding MarkCompleteCommand}" />
                        <Button BackgroundColor="Transparent" FontSize="14" Text="Open related Config page"
                                IsVisible="{Binding SelectedWorkflowViewModel.HasConfigDestination}"
                                Command="{Binding OpenConfigCommand}" />
                    </HorizontalStackLayout>
                    <Label Text="Completion is stored locally and automatically requires review when firmware or parameters change. Prerequisites are guidance, not a rigid wizard." LineBreakMode="WordWrap" Opacity="0.7" />
                </VerticalStackLayout>
            </ScrollView>
    </Grid>
</uranium:UraniumContentPage>
