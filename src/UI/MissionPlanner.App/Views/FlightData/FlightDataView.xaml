<?xml version="1.0" encoding="utf-8" ?>
<uranium:UraniumContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                    xmlns:controls="clr-namespace:MissionPlanner.App.Controls"
                    xmlns:flightData="clr-namespace:MissionPlanner.App.Views.FlightData"
                    xmlns:uranium="http://schemas.enisn-projects.io/dotnet/maui/uraniumui"
                    xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
                    xmlns:tabs="clr-namespace:MissionPlanner.App.Views.FlightData.Tabs"
                    xmlns:hud="clr-namespace:MissionPlanner.App.Views.FlightData.Hud"
                    xmlns:map="clr-namespace:MissionPlanner.App.Views.FlightData.Map"
                    x:Class="MissionPlanner.App.Views.FlightData.FlightDataView"
                    x:DataType="flightData:FlightDataViewModel"
                    
                    >

    <Grid  ColumnDefinitions="Auto,5,*" ColumnSpacing="0" Padding="5,0,0,0" Margin="0,0,0,0">

        <!-- Left column: HUD + action tabs -->
        <Grid Grid.Column="0" RowDefinitions="*,2*" RowSpacing="4">

            <hud:HudView  Grid.Row="0" />
            <StackLayout Grid.Row="1">

                <material:TabView x:Name="TabView" TabHeaderItemColumnWidth="*">

                    <material:TabItem Title="Quick">
                        <tabs:QuickTabView />
                    </material:TabItem>

                    <material:TabItem Title="Actions">
                        <tabs:ActionsTabView />
                    </material:TabItem>
                    <material:TabItem Title="Messages">
                        <tabs:MessagesTabView />
                    </material:TabItem>


                    <material:TabItem Title="PreFlight">
                        <tabs:PreflightTabView />
                    </material:TabItem>
                    <material:TabItem Title="Gauges">
                        <tabs:GaugesTabView />
                    </material:TabItem>
                    <material:TabItem Title="Transponder">
                        <tabs:TransponderTabView />
                    </material:TabItem>
                    <material:TabItem Title="Status">
                        <tabs:StatusTabView />
                    </material:TabItem>

                    <material:TabItem Title="Servo/Relay">
                        <tabs:ServoRelayTabView />
                    </material:TabItem>
                    <material:TabItem Title="Aux Function">
                        <tabs:AuxFunctionTabView />
                    </material:TabItem>

                    <material:TabItem Title="Scripts">
                        <tabs:ScriptsTabView />
                    </material:TabItem>
                    <material:TabItem Title="Payload Control">
                        <tabs:PayloadControlTabView />
                    </material:TabItem>
                    <material:TabItem Title="Telemetry Logs">
                        <tabs:TelemetryLogsTabView />
                    </material:TabItem>
                    <material:TabItem Title="DataFlash Logs">
                        <tabs:DataFlashLogsTabView />
                    </material:TabItem>
                </material:TabView>
            </StackLayout>
        </Grid>

        <!-- Vertical Grid Splitter -->
        <controls:GridSplitter Grid.Column="1" 
                                SplitterThickness="4"
                                SplitterColor="#3e3e42"
                                HoverColor="#007acc" />

        <!-- Right column: telemetry graph + map -->
        <Grid Grid.Column="2" RowDefinitions="*,Auto" RowSpacing="4">

            <map:FlightDataMapView  Grid.Row="0" Margin="10"/>

            <!-- Bottom status bar (mirrors Controls.Status) -->
            <Grid x:Name="StatusBar"
                  Grid.Row="1"
                  ColumnDefinitions="Auto,Auto,Auto"
                  
                  ColumnSpacing="10"
                  BackgroundColor="#2d2d30">

                <Picker 
                        Grid.Column="0"
                        ItemsSource="{Binding MapStyles}"
                        SelectedItem="{Binding SelectedMapStyle}" />
                <Label 
                    Grid.Column="1"
                    Text="text"
                    VerticalOptions="Center" />

                <Label 
                    Grid.Column="2"
                    Text="text"
                    VerticalOptions="Center" />
            </Grid>

        </Grid>

    </Grid>

</uranium:UraniumContentPage>
