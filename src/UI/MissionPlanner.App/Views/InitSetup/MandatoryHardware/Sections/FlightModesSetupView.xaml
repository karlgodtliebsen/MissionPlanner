<?xml version="1.0" encoding="utf-8" ?>
<sections:SetupSectionView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:sections="clr-namespace:MissionPlanner.App.Views.InitSetup.MandatoryHardware.Sections"
             x:Class="MissionPlanner.App.Views.InitSetup.MandatoryHardware.Sections.FlightModesSetupView"
             x:DataType="sections:FlightModesSetupViewModel">
    <VerticalStackLayout Spacing="10">
        <ProgressBar Progress="{Binding Progress}" />
        <Label Text="{Binding Error}" TextColor="Red" />
        <Label Text="Flight-mode assignment" FontSize="18" FontAttributes="Bold" />
        <Label Text="{Binding ModeChannelDescription}" FontAttributes="Bold" />
        <Label Text="{Binding Status}" FontAttributes="Italic" LineBreakMode="WordWrap" />
        <VerticalStackLayout IsVisible="{Binding IsSupported}"
                             BindableLayout.ItemsSource="{Binding Slots}"
                             Spacing="6">
            <BindableLayout.ItemTemplate>
                <DataTemplate x:DataType="sections:FlightModeSlotViewModel">
                    <Border Padding="10" StrokeThickness="1">
                        <Grid ColumnDefinitions="Auto,*,*" ColumnSpacing="8">
                            <Label Text="●" TextColor="LimeGreen" IsVisible="{Binding IsActive}" VerticalOptions="Center" />
                            <Label Grid.Column="1" Text="{Binding BandDescription}" VerticalOptions="Center" />
                            <Picker Grid.Column="2"
                                    Title="Mode"
                                    ItemsSource="{Binding Options}"
                                    SelectedItem="{Binding SelectedMode}"
                                    ItemDisplayBinding="{Binding Name}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </BindableLayout.ItemTemplate>
        </VerticalStackLayout>
        <Button BackgroundColor="Transparent"
                FontSize="14"
                Text="Refresh flight modes"
                Command="{Binding RefreshCommand}"
                HorizontalOptions="Start" />
    </VerticalStackLayout>
</sections:SetupSectionView>
