<?xml version="1.0" encoding="utf-8" ?>
<uranium:UraniumContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                            xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                            xmlns:uranium="http://schemas.enisn-projects.io/dotnet/maui/uraniumui"
                            xmlns:simulation="clr-namespace:MissionPlanner.Core.Simulation;assembly=MissionPlanner.Core"
                            xmlns:vm="clr-namespace:MissionPlanner.App.Views.Simulation"
                            x:Class="MissionPlanner.App.Views.Simulation.SimulationView"
                            x:DataType="vm:SimulationViewModel"
                            Title="Simulation">
    <Grid Padding="18" RowDefinitions="Auto,*" RowSpacing="12">
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <VerticalStackLayout Spacing="3">
                <Label Text="Simulation workspace" FontSize="24" FontAttributes="Bold" />
                <Label Text="Persisted profiles and an owned, observable simulator session. Launch adapters are capability-driven; unavailable runtimes fail explicitly." />
            </VerticalStackLayout>
            <Button Grid.Column="1" Text="Export diagnostics" Command="{Binding ExportDiagnosticsCommand}" VerticalOptions="Center" />
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="0.85*,1.15*" ColumnSpacing="14">
            <ScrollView>
                <VerticalStackLayout Spacing="12">
                    <Border Padding="12">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Profiles" FontSize="18" FontAttributes="Bold" />
                            <Picker Title="Select profile"
                                    ItemsSource="{Binding Profiles}"
                                    ItemDisplayBinding="{Binding Name}"
                                    SelectedItem="{Binding SelectedProfile}" />
                            <HorizontalStackLayout Spacing="8">
                                <Button BackgroundColor="Transparent" FontSize="14" Text="New" Command="{Binding NewProfileCommand}" />
                                <Button BackgroundColor="Transparent" FontSize="14" Text="Save" Command="{Binding SaveProfileCommand}" />
                                <Button BackgroundColor="Transparent" FontSize="14" Text="Delete" Command="{Binding DeleteProfileCommand}" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <Border Padding="12">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="SITL installations" FontSize="18" FontAttributes="Bold" />
                            <Label Text="{Binding PlatformCapability}" />
                            <Picker Title="Installed / configured"
                                    ItemsSource="{Binding Installations}"
                                    ItemDisplayBinding="{Binding DisplayName}"
                                    SelectedItem="{Binding SelectedInstallation}" />
                            <HorizontalStackLayout Spacing="8">
                                <Button BackgroundColor="Transparent" FontSize="14" Text="Refresh" Command="{Binding RefreshInstallationsCommand}" />
                                <Button BackgroundColor="Transparent" FontSize="14" Text="Use selected" Command="{Binding UseSelectedInstallationCommand}" />
                                <Button BackgroundColor="Transparent" FontSize="14" Text="Remove cached"
                                        Command="{Binding RemoveInstallationCommand}"
                                        IsEnabled="{Binding CanRemoveInstallation}" />
                            </HorizontalStackLayout>
                            <Grid ColumnDefinitions="0.7*,1.3*" ColumnSpacing="8">
                                <Picker ItemsSource="{Binding ReleaseChannels}"
                                        SelectedItem="{Binding SelectedReleaseChannel}" />
                                <Picker Grid.Column="1"
                                        Title="Compatible verified release"
                                        ItemsSource="{Binding AvailableReleases}"
                                        ItemDisplayBinding="{Binding DisplayName}"
                                        SelectedItem="{Binding SelectedRelease}" />
                            </Grid>
                            <HorizontalStackLayout Spacing="8">
                                <Button Text="Download, verify, and install"
                                        Command="{Binding InstallReleaseCommand}"
                                        IsEnabled="{Binding CanInstallRelease}" />
                                <Button Text="Cancel"
                                        Command="{Binding CancelOperationCommand}" />
                            </HorizontalStackLayout>
                            <ProgressBar Progress="{Binding InstallProgress}" />
                            <Label Text="{Binding InstallationStatus}" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Padding="12">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Launch profile" FontSize="18" FontAttributes="Bold" />
                            <Label Text="Name" />
                            <Entry Text="{Binding ProfileName}" />
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                <VerticalStackLayout>
                                    <Label Text="Firmware" />
                                    <Picker ItemsSource="{Binding FirmwareFamilies}" SelectedItem="{Binding SelectedFirmwareFamily}" />
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1">
                                    <Label Text="Frame / model" />
                                    <Picker ItemsSource="{Binding AvailableFrames}" SelectedItem="{Binding FrameModel}" />
                                </VerticalStackLayout>
                            </Grid>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                <VerticalStackLayout>
                                    <Label Text="Binary version" />
                                    <Entry Text="{Binding BinaryVersion}" />
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1">
                                    <Label Text="Speedup" />
                                    <Entry Text="{Binding Speedup}" Keyboard="Numeric" />
                                </VerticalStackLayout>
                            </Grid>
                            <Label Text="Absolute executable path" />
                            <Entry Text="{Binding BinaryPath}" Placeholder="Select an installed SITL binary in step 02" />
                            <Label Text="Start location (latitude, longitude, altitude, heading)" />
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <Picker Title="Location preset"
                                        ItemsSource="{Binding LocationPresets}"
                                        ItemDisplayBinding="{Binding Name}"
                                        SelectedItem="{Binding SelectedLocationPreset}" />
                                <Button Grid.Column="1" Text="Apply preset" Command="{Binding ApplyLocationPresetCommand}" />
                            </Grid>
                            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                                <Entry Text="{Binding Latitude}" Keyboard="Numeric" Placeholder="Latitude" />
                                <Entry Grid.Column="1" Text="{Binding Longitude}" Keyboard="Numeric" Placeholder="Longitude" />
                                <Entry Grid.Row="1" Text="{Binding Altitude}" Keyboard="Numeric" Placeholder="Altitude m" />
                                <Entry Grid.Row="1" Grid.Column="1" Text="{Binding Heading}" Keyboard="Numeric" Placeholder="Heading °" />
                            </Grid>
                            <Label Text="Click the map to select latitude/longitude" />
                            <vm:SimulationLocationMapView HeightRequest="220" />
                            <Label Text="Ports" />
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                <Entry Text="{Binding MavLinkPort}" Keyboard="Numeric" Placeholder="MAVLink UDP" />
                                <Entry Grid.Column="1" Text="{Binding ConsolePort}" Keyboard="Numeric" Placeholder="Console TCP" />
                            </Grid>
                            <Label Text="Instance identity" />
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                <Entry Text="{Binding InstanceNumber}" Keyboard="Numeric" Placeholder="Instance (0-254)" />
                                <Entry Grid.Column="1" Text="{Binding SystemId}" Keyboard="Numeric" Placeholder="SystemId (1-255)" />
                            </Grid>
                            <Label Text="Defaults / parameter files (one absolute path per line)" />
                            <Editor Text="{Binding DefaultsFilesText}" AutoSize="TextChanges" MinimumHeightRequest="60" />
                            <Label Text="Additional serial endpoints (index,UdpClient|TcpClient,host,port)" />
                            <Editor Text="{Binding SerialEndpointsText}" AutoSize="TextChanges" MinimumHeightRequest="60" />
                            <HorizontalStackLayout Spacing="12">
                                <CheckBox IsChecked="{Binding WipeState}" />
                                <Label Text="Wipe state" VerticalOptions="Center" />
                                <CheckBox IsChecked="{Binding ShowConsoleWindow}" />
                                <Label Text="Show console" VerticalOptions="Center" />
                                <CheckBox IsChecked="{Binding EnableMapIntegration}" />
                                <Label Text="Map integration" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <Label Text="Additional argument tokens (one token per line)" />
                            <Editor Text="{Binding AdditionalArgumentsText}" AutoSize="TextChanges" MinimumHeightRequest="70" />
                            <Label Text="Environment (one NAME=VALUE per line)" />
                            <Editor Text="{Binding EnvironmentText}" AutoSize="TextChanges" MinimumHeightRequest="70" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Padding="12">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Declarative scenario runner" FontSize="18" FontAttributes="Bold" />
                            <Label Text="Closed schema only. Every step has a timeout; dry-run checks the exact vehicle and required capabilities." />
                            <HorizontalStackLayout Spacing="8">
                                <Button Text="Load JSON" Command="{Binding LoadScenarioDocumentCommand}" />
                                <Button Text="Dry run" Command="{Binding DryRunScenarioCommand}" />
                                <Button Text="Run" Command="{Binding RunScenarioCommand}" />
                                <Button Text="Cancel" Command="{Binding CancelOperationCommand}" />
                            </HorizontalStackLayout>
                            <Editor Text="{Binding ScenarioDocumentText}"
                                    AutoSize="TextChanges"
                                    FontFamily="Consolas"
                                    MinimumHeightRequest="220" />
                            <HorizontalStackLayout Spacing="8">
                                <CheckBox IsChecked="{Binding ScenarioHazardsConfirmed}" />
                                <Label Text="I confirm arm, takeoff, mission start, and fault steps" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="8">
                                <Button Text="Pause at boundary" Command="{Binding PauseScenarioCommand}" />
                                <Button Text="Resume" Command="{Binding ResumeScenarioCommand}" />
                                <Button Text="Export JSON report" Command="{Binding ExportScenarioJsonCommand}" />
                                <Button Text="Export text report" Command="{Binding ExportScenarioTextCommand}" />
                            </HorizontalStackLayout>
                            <Label Text="{Binding ScenarioRunnerStatus}" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </ScrollView>

            <Grid Grid.Column="1" RowDefinitions="Auto,Auto,Auto,*" RowSpacing="12">
                <Border Padding="12">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding SessionState}" FontSize="20" FontAttributes="Bold" />
                            <Label Text="{Binding StatusMessage}" />
                            <Label Text="{Binding FailureMessage}" TextColor="Red" />
                        </VerticalStackLayout>
                        <ActivityIndicator Grid.Column="1" IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
                    </Grid>
                </Border>

                <Border Grid.Row="1" Padding="12">
                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="6">
                        <Label Text="Elapsed" FontAttributes="Bold" />
                        <Label Grid.Column="1" Text="{Binding Elapsed}" />
                        <Label Grid.Row="1" Text="Runtime" FontAttributes="Bold" />
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding RuntimeIdentity}" />
                        <Label Grid.Row="2" Text="Endpoints" FontAttributes="Bold" />
                        <Label Grid.Row="2" Grid.Column="1" Text="{Binding ConnectionEndpoints}" />
                    </Grid>
                </Border>

                <Border Grid.Row="2" Padding="12">
                    <VerticalStackLayout Spacing="7">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <Label Text="Environment, sensors, and bounded faults" FontSize="18" FontAttributes="Bold" />
                            <Button Grid.Column="1" Text="Refresh" Command="{Binding RefreshControlsCommand}" />
                        </Grid>
                        <Picker Title="Documented control"
                                ItemsSource="{Binding ControlCapabilities}"
                                ItemDisplayBinding="{Binding DisplayName}"
                                SelectedItem="{Binding SelectedControl}" />
                        <Label Text="{Binding SelectedControl.Reason}" />
                        <Label Text="{Binding SelectedControl.Descriptor.Description}" />
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                            <Entry Text="{Binding ControlRequestedValue}" Keyboard="Numeric" Placeholder="Requested value" />
                            <Entry Grid.Column="1" Text="{Binding FaultDurationSeconds}" Keyboard="Numeric" Placeholder="Fault duration seconds" />
                        </Grid>
                        <HorizontalStackLayout Spacing="8">
                            <CheckBox IsChecked="{Binding HazardConfirmed}" />
                            <Label Text="I confirm this bounded hazardous injection" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Spacing="8">
                            <Button Text="Apply" Command="{Binding ApplyControlCommand}" IsEnabled="{Binding SelectedControl.IsAvailable}" />
                            <Button Text="Reset" Command="{Binding ResetControlCommand}" />
                        </HorizontalStackLayout>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                            <Entry Text="{Binding ScenarioPresetName}" Placeholder="Scenario preset name" />
                            <Picker Grid.Column="1"
                                    Title="Saved scenario preset"
                                    ItemsSource="{Binding ScenarioPresets}"
                                    ItemDisplayBinding="{Binding Name}"
                                    SelectedItem="{Binding SelectedScenarioPreset}" />
                        </Grid>
                        <HorizontalStackLayout Spacing="8">
                            <Button Text="Save preset" Command="{Binding SaveScenarioPresetCommand}" />
                            <Button Text="Load preset" Command="{Binding LoadScenarioPresetCommand}" />
                            <Button Text="Delete preset" Command="{Binding DeleteScenarioPresetCommand}" />
                        </HorizontalStackLayout>
                        <CollectionView ItemsSource="{Binding ScenarioEvents}" HeightRequest="85">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="simulation:SimulationScenarioEvent">
                                    <Label Text="{Binding Message}" LineBreakMode="TailTruncation" />
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <Grid Grid.Row="3" RowDefinitions="Auto,*" RowSpacing="8">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Label Text="Live stdout / stderr" FontSize="18" FontAttributes="Bold" />
                        <HorizontalStackLayout Grid.Column="1" Spacing="8">
                            <Button BackgroundColor="Transparent" FontSize="14" Text="Start" Command="{Binding StartCommand}" IsEnabled="{Binding CanStart}" />
                            <Button BackgroundColor="Transparent" FontSize="14" Text="Stop" Command="{Binding StopCommand}" IsEnabled="{Binding CanStop}" />
                            <Button BackgroundColor="Transparent" FontSize="14" Text="Restart" Command="{Binding RestartCommand}" IsEnabled="{Binding CanRestart}" />
                        </HorizontalStackLayout>
                    </Grid>
                    <CollectionView Grid.Row="1" ItemsSource="{Binding RecentOutput}">
                        <CollectionView.EmptyView>
                            <Label Text="Runtime output will appear here." Padding="12" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="simulation:SimulatorOutputLine">
                                <Grid Padding="4" ColumnDefinitions="Auto,Auto,*" ColumnSpacing="8">
                                    <Label Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}" />
                                    <Label Grid.Column="1" Text="{Binding Stream}" FontAttributes="Bold" />
                                    <Label Grid.Column="2" Text="{Binding Text}" LineBreakMode="WordWrap" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</uranium:UraniumContentPage>
