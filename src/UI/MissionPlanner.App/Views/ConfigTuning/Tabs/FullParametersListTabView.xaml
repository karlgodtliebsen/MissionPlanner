                                    <Label MaximumWidthRequest="200" MaximumHeightRequest="40" VerticalOptions="Center" HorizontalOptions="Start" Text="{Binding Options}" />
                                </DataTemplate>
                            </material:DataGridColumn.CellItemTemplate>
                        </material:DataGridColumn>

                        <material:DataGridColumn Title="Description">
                            <material:DataGridColumn.CellItemTemplate>
