<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
              xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
              xmlns:tabs="clr-namespace:MissionPlanner.App.Views.FlightData.Tabs"
              x:Class="MissionPlanner.App.Views.FlightData.Tabs.ActionsTabView"
              x:DataType="tabs:ActionsTabViewModel">

    <ScrollView>
        <VerticalStackLayout Padding="12" Spacing="10">
            <Label Text="Vehicle Actions" FontSize="18" FontAttributes="Bold" />
            <Border Padding="8" Stroke="#D97706">
                <Label Text="{Binding DataSourceMode}" FontAttributes="Bold" TextColor="#D97706" />
            </Border>
            <Label Text="{Binding ObservedState}" FontSize="11" LineBreakMode="WordWrap" />

            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                <Button BackgroundColor="Transparent" FontSize="14" Grid.Row="0" Grid.Column="0" Text="Arm" Command="{Binding ArmCommand}" IsEnabled="{Binding CanArm}" />
                <Button BackgroundColor="Transparent" FontSize="14" Grid.Row="0" Grid.Column="1" Text="Disarm" Command="{Binding DisarmCommand}" IsEnabled="{Binding CanDisarm}" />
                <Button BackgroundColor="Transparent" FontSize="14" Grid.Row="1" Grid.Column="0" Text="RTL" Command="{Binding ReturnToLaunchCommand}" IsEnabled="{Binding CanInFlightAction}" />
                <Button BackgroundColor="Transparent" FontSize="14" Grid.Row="1" Grid.Column="1" Text="Loiter / Hold" Command="{Binding HoldCommand}" IsEnabled="{Binding CanInFlightAction}" />
                <Button BackgroundColor="Transparent" FontSize="14" Grid.Row="2" Grid.ColumnSpan="2" Text="Land" Command="{Binding LandCommand}" IsEnabled="{Binding CanInFlightAction}" />
            </Grid>

            <Label Text="Flight mode" FontAttributes="Bold" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Picker Grid.Column="0"
                        ItemsSource="{Binding Modes}"
                        SelectedItem="{Binding SelectedMode}"
                        ItemDisplayBinding="{Binding Name}" />
                <Button BackgroundColor="Transparent" FontSize="14" Grid.Column="1" Text="Set Mode" Command="{Binding SetModeCommand}" IsEnabled="{Binding CanTransmit}" />
            </Grid>

            <Label Text="Takeoff altitude (m)" FontAttributes="Bold" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Entry Grid.Column="0"
                       Keyboard="Numeric"
                       Text="{Binding TakeoffAltitudeMeters}" />
                <Button BackgroundColor="Transparent" FontSize="14" Grid.Column="1" Text="Takeoff" Command="{Binding TakeoffCommand}" IsEnabled="{Binding CanTakeoff}" />
            </Grid>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                <Button BackgroundColor="Transparent" FontSize="12" Grid.Column="0" Text="Set Home Here" Command="{Binding SetHomeHereCommand}" IsEnabled="{Binding CanSetHome}" />
                <Button BackgroundColor="Transparent" FontSize="12" Grid.Column="1" Text="Reboot Autopilot" Command="{Binding RebootCommand}" IsEnabled="{Binding CanReboot}" />
            </Grid>

            <Border Padding="10">
                <VerticalStackLayout Spacing="5">
                    <Label Text="Command status" FontAttributes="Bold" />
                    <Label Text="{Binding PendingCommand, StringFormat='Pending: {0}'}" />
                    <Label Text="{Binding AckResult, StringFormat='ACK: {0}'}" />
                    <Label Text="{Binding OperationState.Message}" LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>

            <HorizontalStackLayout Spacing="8">
                <Label Text="Expert MAV_CMD" VerticalOptions="Center" FontAttributes="Bold" />
                <Switch IsToggled="{Binding IsExpertSectionVisible}" />
            </HorizontalStackLayout>
            <VerticalStackLayout IsVisible="{Binding IsExpertSectionVisible}" Spacing="6">
                <Label Text="Advanced commands can be hazardous. Verify the command ID and all seven parameters." TextColor="OrangeRed" />
                <Entry Placeholder="Command ID" Keyboard="Numeric" Text="{Binding ExpertCommandId}" />
                <Entry Placeholder="Seven invariant parameters, separated by spaces" Text="{Binding ExpertParameters}" />
                <Button BackgroundColor="Transparent" FontSize="14" Text="Validate, Confirm, and Send" Command="{Binding ExecuteExpertCommand}" IsEnabled="{Binding CanTransmit}" />
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>

</ContentView>
